# ─── Telegram Bot ───────────────────────────────
FILESTORE_BOT_TOKEN=your_telegram_bot_token_here

# ─── MongoDB ────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# ─── Telegram Storage Channel ───────────────────
# Channel ID where media will be copied (e.g. -1001234567890)
STORAGE_CHANNEL_ID=-1001234567890

# ─── Cloudflare Worker ──────────────────────────
# Your worker URL without trailing slash
WORKER_URL=your.workers.dev

# ─── URL Shortener ──────────────────────────────
SHORTENER_DOMAIN=viralbox.in
SHORTENER_API_ENDPOINT=https://viralbox.in/api?api=

# ─── Bot Info ───────────────────────────────────
INFO_VIDEO_1=https://youtu.be/your_info_video_link
ADMIN_USERNAME=@your_admin_username
